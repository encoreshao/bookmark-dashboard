{
  "manifest_version": 3,
  "name": "Bookmark Dashboard - AI Powered",
  "short_name": "Bookmarks",
  "version": "2.1.2",
  "description": "Replace your new tab with an AI-powered bookmark dashboard. Search, organize and analyze your bookmarks with smart AI insights.",
  "author": "Encore Shao",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "js/service-worker.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "options_page": "options/index.html",
  "commands": {
    "open-ai-tag": {
      "description": "Open AI tag popup for current page"
    }
  },
  "permissions": [
    "bookmarks",
    "storage",
    "favicon",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "js/*", "styles/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
